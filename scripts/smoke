#!/usr/bin/env bash
# Proves, on this machine's real archives, that the suite works. Four
# questions per crawler: is the archive fresh, does it honour the
# contract, does search -> open round-trip on real data, and do the
# README's documented commands actually exist. Then cross-source: do
# real questions get real answers through trawl.
#
# The script is generic and holds no personal data. Personal probe
# queries live in an uncommitted local file, ~/.trawl/smoke.jsonl, one
# JSON object per line:
#   {"query": "boat trip", "source": "imsgcrawl", "expect": "Saturday"}
# "source" and "expect" are optional: source pins where a hit must come
# from, expect is a substring that must appear in some result snippet.
# Without the file, the cross-source section runs a generic probe only.
#
# Output is a human report for the owner's eyes; it prints archive
# content, so it never belongs in a commit, an issue, or CI logs.
#
# Every raw crawler output the run elicits is also saved, untruncated,
# under ~/.trawl/smoke-raw/<timestamp>/. The script only checks what a
# script can check; a model reads that transcript afterwards and judges
# whether the outputs are actually correct — that review is part of the
# gate, not an optional extra.
set -uo pipefail

repo="$(cd "$(dirname "$0")/.." && pwd)"
bin="$repo/.dev/bin"
queries="${TRAWL_SMOKE_QUERIES:-$HOME/.trawl/smoke.jsonl}"
rawdir="$HOME/.trawl/smoke-raw/$(date +%Y%m%d-%H%M%S)"
mkdir -p "$rawdir"
export PATH="$bin:$PATH"

pass=0 fail=0 warn=0
declare -a failures

ok()  { pass=$((pass + 1)); printf '  pass  %s\n' "$1"; }
bad() { fail=$((fail + 1)); failures+=("$1"); printf '  FAIL  %s\n' "$1"; }
meh() { warn=$((warn + 1)); printf '  warn  %s\n' "$1"; }
skip() { warn=$((warn + 1)); printf '  SKIP  %s\n' "$1"; }

slug() {
  local value out
  value="$1"
  out="$(printf '%s' "$value" | tr -c 'a-zA-Z0-9' '-' | sed 's/^-*//; s/-*$//; s/--*/-/g' | cut -c1-80)"
  [ -n "$out" ] || out="x"
  printf '%s' "$out"
}

capture() {
  local stdout stderr
  stdout="$1"
  stderr="$2"
  shift 2
  "$@" >"$stdout" 2>"$stderr"
}

json_declares_capability() {
  local file capability
  file="$1"
  capability="$2"
  jq -r --arg capability "$capability" \
    '(.capabilities // []) | map(ascii_downcase) | contains([$capability])' \
    "$file" 2>/dev/null
}

valid_who_json() {
  jq -e '
    (.query | type == "string" and length > 0) and
    (.candidates | type == "array") and
    all(.candidates[]; ((.who // "") | type == "string" and length > 0) and ((.identifiers // null) | type == "array"))
  ' "$1" >/dev/null 2>&1
}

valid_search_who_json() {
  jq -e '
    (.query | type == "string") and
    (.who_resolved.who | type == "string" and length > 0) and
    (.who_resolved.identifiers | type == "array") and
    (.results | type == "array" and length > 0)
  ' "$1" >/dev/null 2>&1
}

valid_unknown_who_json() {
  jq -e '
    (.error.code == "unknown_who") and
    (
      has("did_you_mean") or
      ((.error // {}) | has("did_you_mean")) or
      (((.hint // .error.hint // .error.remedy // .error.message // "") | tostring | ascii_downcase) | contains("without --who"))
    )
  ' "$1" >/dev/null 2>&1
}

valid_ambiguous_who_json() {
  jq -e '
    (.error.code == "ambiguous_who") and
    (.candidates | type == "array" and length > 0)
  ' "$1" >/dev/null 2>&1
}

search_words_from_results() {
  jq -r '(.results // [])[:3][] | [.snippet, .where, .who] | map(. // "") | join(" ")' "$1" 2>/dev/null |
    tr -cs '[:alnum:]' '\n' |
    awk 'length($0) >= 3 && $0 !~ /^[0-9]+$/ {print; n++; if (n == 8) exit}'
}

first_repeated_who_token() {
  jq -r '
    [(.candidates // [])[].who | strings | split(" ")[0] | select(length >= 2)] |
    group_by(ascii_downcase)[]? |
    select(length >= 2) |
    .[0]
  ' "$1" 2>/dev/null | head -1
}

check_human_who_capture() {
  local surface file first
  surface="$1"
  file="$2"
  if [ ! -s "$file" ]; then
    bad "$surface who human output is empty"
    return
  fi
  first="$(head -1 "$file")"
  case "$first" in
    \{*|\[*)
      bad "$surface who human output leaks JSON" ;;
    *"%!"*|*"map["*|*"{[{"*)
      bad "$surface who human output prints raw Go values" ;;
    *)
      ok "$surface who human output is prose" ;;
  esac
}

who_fragments=(al an ar de el er in la ma on a e i o n r s t)
unknown_who_token="zzqx-nobody"
trawl_ambiguous_who=""

run_who_contract_smoke() {
  local surface command state declares_search found command_succeeded fragment tag json err human count exact_name filter_json filter_err words word search_tag search_json search_err search_ok ambiguous
  surface="$1"
  command="$2"
  state="$3"
  declares_search="$4"
  found=""
  command_succeeded=""

  for fragment in "${who_fragments[@]}"; do
    tag="$(slug "$surface-who-$fragment")"
    json="$rawdir/$tag.json"
    err="$rawdir/$tag.stderr.txt"
    if capture "$json" "$err" "$command" who "$fragment" --json; then
      command_succeeded=1
      if ! valid_who_json "$json"; then
        bad "$surface who JSON is missing query, candidates, who, or identifiers"
        return
      fi
      count="$(jq -r '(.candidates // []) | length' "$json" 2>/dev/null)"
      if [ "${count:-0}" -gt 0 ]; then
        found=1
        human="$rawdir/$tag-human.txt"
        capture "$human" "$rawdir/$tag-human.stderr.txt" "$command" who "$fragment"
        ok "$surface who JSON envelope"
        check_human_who_capture "$surface" "$human"
        exact_name="$(jq -r '.candidates[0].who // empty' "$json")"
        if [ -z "$trawl_ambiguous_who" ] && [ "$command" != "trawl" ] && [ "$count" -ge 2 ]; then
          ambiguous="$(first_repeated_who_token "$json")"
          if [ -z "$ambiguous" ] && [ "${#fragment}" -ge 2 ]; then
            ambiguous="$fragment"
          fi
          trawl_ambiguous_who="$ambiguous"
        fi
        break
      fi
    fi
  done

  if [ -z "$found" ]; then
    if [ -z "$command_succeeded" ] && { [ "$state" = "ok" ] || [ "$state" = "stale" ]; }; then
      bad "$surface who failed for all common fragments"
    else
      skip "$surface who v1.2: no candidates from common fragments"
    fi
    if [ "$declares_search" = "true" ] && { [ "$state" = "ok" ] || [ "$state" = "stale" ]; }; then
      run_unknown_who_smoke "$surface" "$command" "the"
    fi
    return
  fi

  if [ "$declares_search" != "true" ]; then
    skip "$surface search --who: metadata does not declare search"
    return
  fi

  filter_json="$rawdir/$(slug "$surface-search-who-filter-only").json"
  filter_err="$rawdir/$(slug "$surface-search-who-filter-only").stderr.txt"
  if ! capture "$filter_json" "$filter_err" "$command" search --who "$exact_name" --json --limit 1; then
    bad "$surface search --who failed while discovering a probe word"
    run_unknown_who_smoke "$surface" "$command" "the"
    return
  fi

  words="$(search_words_from_results "$filter_json")"
  [ -n "$words" ] || words="the"
  search_ok=""
  for word in $words; do
    search_tag="$(slug "$surface-search-who-$word")"
    search_json="$rawdir/$search_tag.json"
    search_err="$rawdir/$search_tag.stderr.txt"
    if capture "$search_json" "$search_err" "$command" search "$word" --who "$exact_name" --json --limit 3; then
      if grep -q '"who_matched"[[:space:]]*:' "$search_json"; then
        bad "$surface search --who JSON still contains who_matched"
        run_unknown_who_smoke "$surface" "$command" "${word:-the}"
        return
      fi
      if valid_search_who_json "$search_json"; then
        ok "$surface search --who resolves, returns results, and omits who_matched"
        search_ok=1
        break
      fi
    elif grep -q '"who_matched"[[:space:]]*:' "$search_json" 2>/dev/null; then
      bad "$surface search --who JSON still contains who_matched"
      run_unknown_who_smoke "$surface" "$command" "${word:-the}"
      return
    fi
  done
  if [ -z "$search_ok" ]; then
    bad "$surface search --who JSON lacks who_resolved or results"
    run_unknown_who_smoke "$surface" "$command" "${word:-the}"
    return
  fi

  run_unknown_who_smoke "$surface" "$command" "$word"
}

run_unknown_who_smoke() {
  local surface command word unknown_json unknown_err unknown_code
  surface="$1"
  command="$2"
  word="$3"
  unknown_json="$rawdir/$(slug "$surface-search-who-unknown").json"
  unknown_err="$rawdir/$(slug "$surface-search-who-unknown").stderr.txt"
  capture "$unknown_json" "$unknown_err" "$command" search "$word" --who "$unknown_who_token" --json --limit 3
  unknown_code=$?
  if [ "$unknown_code" -ne 5 ]; then
    bad "$surface unknown --who exit = $unknown_code, want 5"
    return
  fi
  if valid_unknown_who_json "$unknown_json"; then
    ok "$surface unknown --who returns unknown_who with guidance"
  else
    bad "$surface unknown --who JSON lacks unknown_who, did_you_mean, or hint"
  fi
}

run_trawl_ambiguous_who_smoke() {
  local json err code
  if [ -z "$trawl_ambiguous_who" ]; then
    skip "trawl ambiguous --who: no crawler who output exposed two candidates"
    return
  fi
  json="$rawdir/trawl-search-who-ambiguous.json"
  err="$rawdir/trawl-search-who-ambiguous.stderr.txt"
  capture "$json" "$err" trawl search "the" --who "$trawl_ambiguous_who" --json --limit 3
  code=$?
  if [ "$code" -ne 4 ]; then
    bad "trawl ambiguous --who exit = $code, want 4"
    return
  fi
  if valid_ambiguous_who_json "$json"; then
    ok "trawl ambiguous --who returns ambiguous_who candidates"
  else
    bad "trawl ambiguous --who JSON lacks ambiguous_who candidates"
  fi
}

[ -x "$bin/trawl" ] || { echo "run scripts/dev-bin first" >&2; exit 1; }

echo "== sources =="
trawl status --json > "$rawdir/trawl-status.json" 2>/dev/null
sources="$(jq -r '.[] | "\(.app_id) \(.state)"' "$rawdir/trawl-status.json")"
if [ -z "$sources" ]; then
  echo "trawl status --json returned nothing usable" >&2
  exit 1
fi
printf '%s\n' "$sources" | sed 's/^/  /'

while read -r source state; do
  echo
  echo "== $source =="

  # 1. Fresh: an archive that exists must be current. "missing" means
  # never set up on this machine — flagged, but not a failure.
  case "$state" in
    ok) ok "state ok" ;;
    stale) meh "state stale — run: trawl sync $source" ;;
    empty) meh "state empty — archive exists but holds nothing yet" ;;
    missing) meh "state missing — not set up on this machine" ;;
    *) bad "state $state" ;;
  esac

  # 2. Contract: the conformance harness is the machine-checkable part.
  if conformance "$source" >/dev/null 2>&1; then
    ok "conformance"
  else
    bad "conformance (run: conformance $source)"
  fi

  metadata_json="$rawdir/$source-metadata.json"
  metadata_err="$rawdir/$source-metadata.stderr.txt"
  if capture "$metadata_json" "$metadata_err" "$source" metadata --json; then
    declares_search="$(json_declares_capability "$metadata_json" "search")"
    [ "$declares_search" = "true" ] || declares_search=false
    declares_who="$(json_declares_capability "$metadata_json" "who")"
    [ "$declares_who" = "true" ] || declares_who=false
  else
    declares_search=false
    declares_who=false
    bad "metadata --json failed for capability discovery"
  fi

  # 3. Round-trip on real data: search issues a ref, open expands it.
  # Only meaningful when the crawler declares search and has an archive.
  if [ "$declares_search" = "true" ] && { [ "$state" = "ok" ] || [ "$state" = "stale" ]; }; then
    "$source" search "the" --json --limit 3 > "$rawdir/$source-search.json" 2>/dev/null
    ref="$(jq -r '.results[0].ref // empty' "$rawdir/$source-search.json" 2>/dev/null)"
    if [ -z "$ref" ]; then
      meh "round-trip skipped: search \"the\" matched nothing"
    elif "$source" open "$ref" --json > "$rawdir/$source-open.json" 2>&1; then
      ok "search → open round-trip ($ref)"
    else
      bad "open failed on ref search issued: $ref"
    fi
  fi

  # 4. Human output is a first-class surface: capture it raw for the
  # model review, and catch outputs that are not even prose — leaked
  # JSON, Go struct dumps, fmt errors. The JSON side is covered above;
  # both modes go into the transcript.
  for verb in status doctor; do
    out="$("$source" "$verb" 2>&1 | head -40)"
    printf '%s\n' "$out" > "$rawdir/$source-$verb-human.txt"
    case "$out" in
      ""|\{*|\[*)
        bad "$verb human output is empty or leaks JSON" ;;
      *"%!"*|*"map["*|*"{[{"*)
        bad "$verb human output prints raw Go values" ;;
      *) ok "$verb human output is prose" ;;
    esac
  done
  if [ "$declares_search" = "true" ] && { [ "$state" = "ok" ] || [ "$state" = "stale" ]; }; then
    "$source" search "the" --limit 3 > "$rawdir/$source-search-human.txt" 2>&1
    if [ -n "$ref" ]; then
      "$source" open "$ref" > "$rawdir/$source-open-human.txt" 2>&1
    fi
  fi

  # 5. Contract v1.2 who surfaces: discover a real archived person
  # dynamically from who output, then prove search --who resolution.
  if [ "$declares_who" = "true" ]; then
    run_who_contract_smoke "$source" "$source" "$state" "$declares_search"
  fi

  # 6. Documented truthfully: every "$source <verb>" line the README
  # shows in a shell block must at least be a real command.
  readme="$repo/$source/README.md"
  if [ -f "$readme" ]; then
    verbs="$(awk '/^```/{code=!code; next} code && $1 == "'"$source"'" {print $2}' "$readme" | sort -u)"
    for verb in $verbs; do
      case "$verb" in -*|"") continue ;; esac
      if "$source" "$verb" --help >/dev/null 2>&1; then
        ok "README documents a real command: $verb"
      else
        bad "README documents \"$source $verb\" but the command fails --help"
      fi
    done
  else
    meh "no README at $source/README.md"
  fi
done <<< "$sources"

echo
echo "== contract v1.2 who, through trawl =="
run_who_contract_smoke "trawl" "trawl" "ok" "true"
run_trawl_ambiguous_who_smoke

echo
echo "== cross-source, through trawl =="
trawl status > "$rawdir/trawl-status-human.txt" 2>&1
trawl search "the" --limit 5 > "$rawdir/trawl-search-human.txt" 2>&1
probe() { # probe <query> <source-or-empty> -> search results JSON
  local capture="$rawdir/trawl-search-$(echo "$1" | tr -c 'a-zA-Z0-9' '-').json"
  if [ -n "$2" ]; then
    trawl search "$1" --json --limit 20 --source "$2" 2>/dev/null
  else
    trawl search "$1" --json --limit 20 2>/dev/null
  fi | tee "$capture"
}
if [ -f "$queries" ]; then
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    query="$(jq -r '.query' <<<"$line")"
    source="$(jq -r '.source // empty' <<<"$line")"
    expect="$(jq -r '.expect // empty' <<<"$line")"
    results="$(probe "$query" "$source" | jq '.results // []')"
    if [ "$(jq 'length' <<<"${results:-[]}")" = "0" ]; then
      bad "no results for: $query"
      continue
    fi
    if [ -n "$expect" ] &&
      ! jq -e --arg want "$expect" \
        'map(.snippet // "" | ascii_downcase) | any(contains($want | ascii_downcase))' \
        <<<"$results" >/dev/null; then
      bad "results for \"$query\" never mention \"$expect\""
      continue
    fi
    ok "\"$query\" → $(jq -r '.[0] | "\(.source) \(.time[:10] // "") \(.snippet[:60] // "")"' <<<"$results")"
  done < "$queries"
else
  meh "no $queries — cross-source checks ran no personal probes"
  if [ "$(probe "the" "" | jq '.results // [] | length')" -gt "0" ] 2>/dev/null; then
    ok "trawl search federates and returns results"
  else
    bad "trawl search returned no results across all sources"
  fi
fi

echo
echo "== verdict: $pass pass, $warn warn, $fail fail =="
for f in "${failures[@]-}"; do [ -n "$f" ] && echo "  FAIL: $f"; done
echo "raw transcript for model review: $rawdir"
[ "$fail" -eq 0 ]
