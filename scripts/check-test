#!/usr/bin/env bash
set -euo pipefail

root=$(git rev-parse --show-toplevel)
cd "$root"

# Exact-output fixtures render local times. Pin the test process so their
# contract is independent of the developer or CI runner's timezone.
export TZ=Europe/Amsterdam

modules=()
while IFS= read -r module; do
  modules+=("$module")
done < <(
  git ls-files |
    sed -n -e 's#^go\.mod$#.#p' -e 's#/go\.mod$##p' |
    sort
)

for module in "${modules[@]}"; do
  echo "test: $module"
  (
    cd "$root/$module"
    go test -p=2 ./...
  )
done

echo "test: generated app protobufs"
app/scripts/generate-app-protobuf --check

echo "test: app"
app_test_root="$(mktemp -d "${TMPDIR:-/tmp}/opentrawl-app-test.XXXXXX")"
trap 'rm -rf "$app_test_root"' EXIT
helper="$app_test_root/trawl"
synthetic_home="$app_test_root/home"
isolated_state_root="$app_test_root/alpha-state"
mkdir -p "$synthetic_home"
(
  cd "$root/trawl"
  go build -o "$helper" ./cmd/trawl
)
(
  cd "$root/trawlers/contacts"
  go run ./internal/testfixture/cmd/seed \
    --archive "$synthetic_home/.opentrawl/contacts/contacts.db" \
    --id avery-example \
    --name "Avery Example" \
    --email avery@example.com
  go run ./internal/testfixture/cmd/seed \
    --archive "$isolated_state_root/contacts/contacts.db" \
    --id jordan-isolated \
    --name "Jordan Isolated" \
    --email jordan@example.com
)
swift_env=(
  HOME="$synthetic_home"
  PATH="/usr/bin:/bin:/usr/sbin:/sbin"
  OPENTRAWL_TEST_TRAWL="$helper"
  OPENTRAWL_TEST_STATE_ROOT="$isolated_state_root"
)
if [[ "${GITHUB_ACTIONS:-}" == "true" ]]; then
  swift_env+=(OPENTRAWL_SKIP_WINDOW_FOCUS_TESTS=1)
fi
/usr/bin/env -i "${swift_env[@]}" /usr/bin/xcrun swift test --package-path "$root/app" --no-parallel

echo "check-test: ok"
