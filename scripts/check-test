#!/usr/bin/env bash
set -euo pipefail

root=$(git rev-parse --show-toplevel)
cd "$root"

# Exact-output fixtures render local times. Pin the test process so their
# contract is independent of the developer or CI runner's timezone.
export TZ=Europe/Amsterdam

modules=()
while IFS= read -r module; do
  modules+=("$module")
done < <(
  git ls-files |
    sed -n -e 's#^go\.mod$#.#p' -e 's#/go\.mod$##p' |
    sort
)

for module in "${modules[@]}"; do
  echo "test: $module"
  (
    cd "$root/$module"
    go test -p=2 ./...
  )
done

echo "test: generated app protobufs"
app/scripts/generate-app-protobuf --check

echo "test: app"
app_test_root="$(mktemp -d "${TMPDIR:-/tmp}/opentrawl-app-test.XXXXXX")"
trap 'rm -rf "$app_test_root"' EXIT
helper="$app_test_root/trawl"
synthetic_home="$app_test_root/home"
isolated_state_root="$app_test_root/alpha-state"
mkdir -p "$synthetic_home"
(
  cd "$root/trawl"
  go build -o "$helper" ./cmd/trawl
)
(
  cd "$root/trawlers/contacts"
  go run ./internal/testfixture/cmd/seed \
    --archive "$synthetic_home/.opentrawl/contacts/contacts.db" \
    --id avery-example \
    --name "Avery Example" \
    --email avery@example.com
  go run ./internal/testfixture/cmd/seed \
    --archive "$isolated_state_root/contacts/contacts.db" \
    --id jordan-isolated \
    --name "Jordan Isolated" \
    --email jordan@example.com
)

echo "test: installed-shape human CLI"
human_cli_env=(
  HOME="$synthetic_home"
  PATH="/usr/bin:/bin:/usr/sbin:/sbin"
)
front_door=$(/usr/bin/env -i "${human_cli_env[@]}" "$helper")
full_help=$(/usr/bin/env -i "${human_cli_env[@]}" "$helper" --help)
for expected in \
  "Messages" "WhatsApp" "Telegram" "Notes" "Contacts" \
  "trawl search" "trawl open" "trawl chats" "trawl who" "Agents:"; do
  if [[ "$front_door" != *"$expected"* && "$full_help" != *"$expected"* ]]; then
    echo "installed helper discovery is missing: $expected" >&2
    exit 1
  fi
done
for hidden in "Gmail" "Calendar" "Photos" "Twitter (X)"; do
  if [[ "$front_door" == *"$hidden"* || "$full_help" == *"$hidden"* ]]; then
    echo "installed helper discovery exposed experimental source: $hidden" >&2
    exit 1
  fi
done
for source in imessage whatsapp telegram notes contacts; do
  /usr/bin/env -i "${human_cli_env[@]}" "$helper" "$source" >/dev/null
done
search_output=$(/usr/bin/env -i "${human_cli_env[@]}" "$helper" search "Avery Example" --source contacts)
open_output=$(/usr/bin/env -i "${human_cli_env[@]}" "$helper" open contacts:person/avery-example)
who_errors="$app_test_root/who-errors"
set +e
who_output=$(/usr/bin/env -i "${human_cli_env[@]}" "$helper" who "Avery Example" 2>"$who_errors")
who_status=$?
set -e
chats_errors="$app_test_root/chats-errors"
set +e
chats_output=$(/usr/bin/env -i "${human_cli_env[@]}" "$helper" chats --limit 1 2>"$chats_errors")
chats_status=$?
set -e
for output in "$search_output" "$open_output" "$who_output"; do
  if [[ "$output" != *"Avery Example"* ]]; then
    echo "installed helper did not complete the synthetic search/open/people flow" >&2
    exit 1
  fi
done
if [[ "$who_status" -ne 3 ]] || ! grep -q "Messages who failed" "$who_errors"; then
  echo "installed helper did not preserve the usable people result while explaining missing messaging archives" >&2
  exit 1
fi
if [[ "$chats_status" -ne 1 ]] || [[ "$chats_output" != *"No messaging archives found"* ]] || ! grep -q "Unavailable chat sources" "$chats_errors"; then
  echo "installed helper did not explain the synthetic no-chats state" >&2
  exit 1
fi

swift_env=(
  HOME="$synthetic_home"
  PATH="/usr/bin:/bin:/usr/sbin:/sbin"
  OPENTRAWL_TEST_TRAWL="$helper"
  OPENTRAWL_TEST_STATE_ROOT="$isolated_state_root"
)
if [[ "${GITHUB_ACTIONS:-}" == "true" ]]; then
  swift_env+=(OPENTRAWL_SKIP_WINDOW_FOCUS_TESTS=1)
fi
/usr/bin/env -i "${swift_env[@]}" /usr/bin/xcrun swift test --package-path "$root/app" --no-parallel

echo "check-test: ok"
