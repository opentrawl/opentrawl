#!/usr/bin/env bash
# Two-way git subtree sync between this monorepo and crawler upstreams.
#
#   scripts/sync list          show the sync table
#   scripts/sync pull <dir>    absorb upstream main into <dir>
#   scripts/sync push <dir>    split <dir> and push branch trawl-sync-<dir>
#                              to the outbound repo, then print the PR
#                              command
#
# Direct rows push straight to the upstream (we have maintainer access).
# Fork rows push to the fork; open the PR against the upstream.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

# dir  upstream  outbound
table() {
  cat <<'EOF'
trawlkit          https://github.com/opentrawl/opentrawl/trawlkit.git    https://github.com/opentrawl/opentrawl/trawlkit.git
trawlers/imessage https://github.com/openclaw/imsgcrawl.git   https://github.com/openclaw/imsgcrawl.git
trawlers/photos   https://github.com/openclaw/photoscrawl.git https://github.com/openclaw/photoscrawl.git
trawlers/telegram https://github.com/openclaw/telecrawl.git   git@github.com:joshp123/telecrawl.git
trawlers/whatsapp https://github.com/openclaw/wacrawl.git     git@github.com:joshp123/wacrawl.git
trawlers/contacts https://github.com/openclaw/clawdex.git     git@github.com:joshp123/clawdex.git
EOF
}

row() { table | awk -v d="$1" '$1 == d {print; found=1} END {exit !found}'; }

cmd="${1:-list}"
case "$cmd" in
list)
  table
  ;;
pull)
  dir="$2"
  upstream=$(row "$dir" | awk '{print $2}')
  git subtree pull --prefix="$dir" "$upstream" main \
    -m "sync: pull $dir from upstream"
  ;;
push)
  dir="$2"
  upstream=$(row "$dir" | awk '{print $2}')
  outbound=$(row "$dir" | awk '{print $3}')
  branch="trawl-sync-$dir"
  git subtree push --prefix="$dir" "$outbound" "$branch"
  echo
  echo "pushed $branch to $outbound"
  if [ "$outbound" = "$upstream" ]; then
    echo "open the PR: gh pr create --repo ${upstream#https://github.com/} --head $branch"
  else
    fork=${outbound#git@github.com:}; fork=${fork%.git}
    echo "open the PR: gh pr create --repo ${upstream#https://github.com/} --head ${fork%%/*}:$branch"
  fi
  ;;
*)
  echo "usage: scripts/sync [list|pull <dir>|push <dir>]" >&2
  exit 1
  ;;
esac
