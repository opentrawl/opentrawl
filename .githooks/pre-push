#!/usr/bin/env bash
set -euo pipefail

root=$(git rev-parse --show-toplevel)
remote_name=${1:-origin}
zero=0000000000000000000000000000000000000000

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_sha" == "$zero" ]]; then
    continue
  fi

  if git merge-base --is-ancestor demo "$local_sha" >/dev/null 2>&1; then
    echo "push rejected: $local_ref reaches the private demo branch" >&2
    exit 1
  fi

  commits=$(git rev-list "$local_sha" --not --remotes="$remote_name")
  if [[ -n "$commits" ]]; then
    while IFS= read -r commit; do
      "$root/scripts/check-clean" --tree "$commit"
    done <<<"$commits"
  else
    "$root/scripts/check-clean" --tree "$local_sha"
  fi

  if [[ "$remote_ref" == "refs/heads/main" && "${OPENTRAWL_LAND_MAIN:-}" != "1" ]]; then
    echo "direct main push rejected locally; use scripts/land-main" >&2
    exit 1
  fi
done
