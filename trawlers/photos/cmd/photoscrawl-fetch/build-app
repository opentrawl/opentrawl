#!/usr/bin/env bash
# Build one signed PhotoKit app at the requested path.
set -euo pipefail

usage() {
  echo "usage: build-app --output OUTPUT.app" >&2
  exit 2
}

if [[ $# -ne 2 || "$1" != "--output" || -z "$2" ]]; then
  usage
fi

app="${2%/}"
if [[ "$app" != *.app ]]; then
  usage
fi
if [[ -e "$app" || -L "$app" ]]; then
  echo "build-app: output already exists: $app" >&2
  exit 1
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/../../../.." && pwd)"
identity="OpenTrawl Dev Signing"
keychain="opentrawl-dev.keychain"
contents="$app/Contents"
binary="$contents/MacOS/photoscrawl-fetch"
entitlements="$repo_root/trawlers/photos/cmd/photoscrawl-fetch/PhotoKit.entitlements"
signing_entitlements="$(mktemp "${TMPDIR:-/tmp}/photoscrawl-fetch-entitlements.XXXXXX")"
trap 'rm -f "$signing_entitlements"' EXIT

"$repo_root/scripts/dev-cert"
plutil -convert xml1 -o "$signing_entitlements" "$entitlements"
mkdir -p "$contents/MacOS"
cp "$repo_root/trawlers/photos/cmd/photoscrawl-fetch/Info.plist" "$contents/Info.plist"
(
  cd "$repo_root/trawlers/photos"
  go build -o "$binary" ./cmd/photoscrawl-fetch
)
codesign --force --sign "$identity" --keychain "$keychain" \
  --options runtime --timestamp=none \
  --identifier org.opentrawl.photoscrawl.fetch \
  --entitlements "$signing_entitlements" \
  "$app"
codesign --verify --deep --strict --verbose=2 "$app"
