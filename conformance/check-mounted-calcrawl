#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT

export CGO_ENABLED="${CGO_ENABLED:-1}"
export GOFLAGS="${GOFLAGS:--tags=sqlite_fts5}"

calcrawl_bin="$tmp_dir/calcrawl"
(
  cd "$repo_root/calcrawl"
  go build -o "$calcrawl_bin" ./cmd/calcrawl
)

(
  cd "$repo_root/conformance"
  OPENTRAWL_CONFORMANCE_CALCRAWL_PLUGIN="$calcrawl_bin" \
    go test -count=1 -run TestMountedCalcrawlPlugin -v ./internal/harness
)
