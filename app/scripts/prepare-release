#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: app/scripts/prepare-release \
  --version VERSION \
  --output DIR \
  [--identity IDENTITY] \
  [--notary-key FILE] \
  [--notary-key-id-file FILE] \
  [--notary-issuer-file FILE] \
  [--sparkle-private-key FILE]

Builds, signs, notarises and verifies an unpublished release candidate using
the explicit local release credentials. This command cannot publish.
EOF
  exit 2
}

version=""
output=""
identity=""
release_config="${OPENTRAWL_RELEASE_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/opentrawl/release}"
notary_key="$release_config/app-store-connect-api-key.p8"
notary_key_id_file="$release_config/app-store-connect-key-id"
notary_issuer_file="$release_config/app-store-connect-issuer-id"
sparkle_private_key="$release_config/sparkle-ed25519-private-key"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version) version="${2:-}"; shift 2 ;;
    --output) output="${2:-}"; shift 2 ;;
    --identity) identity="${2:-}"; shift 2 ;;
    --notary-key) notary_key="${2:-}"; shift 2 ;;
    --notary-key-id-file) notary_key_id_file="${2:-}"; shift 2 ;;
    --notary-issuer-file) notary_issuer_file="${2:-}"; shift 2 ;;
    --sparkle-private-key) sparkle_private_key="${2:-}"; shift 2 ;;
    *) usage ;;
  esac
done

[[ -n "$version" && -n "$output" ]] || usage
[[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ && "$version" != "0.0.0" ]] || {
  echo "prepare-release: version must use x.y.z form and cannot be 0.0.0" >&2
  exit 1
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/../.." && pwd)"
notes="$repo_root/app/Release/notes/$version.md"
public_key_file="$repo_root/app/Release/SparklePublicKey"
tag="v$version"

for command in gh git openssl security shasum tail xcrun xxd; do
  command -v "$command" >/dev/null || {
    echo "prepare-release: required command is missing: $command" >&2
    exit 1
  }
done
[[ -s "$notes" ]] || {
  echo "prepare-release: add human release notes at $notes" >&2
  exit 1
}
[[ -s "$public_key_file" ]] || {
  echo "prepare-release: missing Sparkle public key: $public_key_file" >&2
  exit 1
}
[[ -s "$notary_key" && -s "$notary_key_id_file" && -s "$notary_issuer_file" ]] || {
  echo "prepare-release: missing App Store Connect team API credentials in $release_config" >&2
  echo "prepare-release: run app/scripts/setup-release-credentials" >&2
  exit 1
}
[[ -s "$sparkle_private_key" ]] || {
  echo "prepare-release: missing Sparkle private key: $sparkle_private_key" >&2
  echo "prepare-release: restore it from backup or run setup-release-credentials --create-sparkle-key before the first public release" >&2
  exit 1
}
if [[ -e "$output" || -L "$output" ]]; then
  echo "prepare-release: output already exists: $output" >&2
  exit 1
fi
if [[ -n "$(git -C "$repo_root" status --porcelain)" ]]; then
  echo "prepare-release: the release worktree must be clean" >&2
  exit 1
fi

echo "Checking exact main and release availability"
git -C "$repo_root" fetch origin main --tags
commit="$(git -C "$repo_root" rev-parse HEAD)"
main="$(git -C "$repo_root" rev-parse origin/main)"
[[ "$commit" == "$main" ]] || {
  echo "prepare-release: HEAD must equal current origin/main" >&2
  exit 1
}
if gh release view --repo opentrawl/opentrawl "$tag" >/dev/null 2>&1; then
  echo "prepare-release: release $tag already exists" >&2
  exit 1
fi
if git -C "$repo_root" rev-parse -q --verify "refs/tags/$tag" >/dev/null; then
  echo "prepare-release: tag $tag already exists" >&2
  exit 1
fi

if [[ -z "$identity" ]]; then
  identities=()
  while IFS= read -r found; do
    identities+=("$found")
  done < <(
    security find-identity -v -p codesigning |
      sed -n 's/.*"\(Developer ID Application:.*\)"/\1/p'
  )
  if [[ "${#identities[@]}" -ne 1 ]]; then
    echo "prepare-release: expected one valid Developer ID Application identity; found ${#identities[@]}" >&2
    exit 1
  fi
  identity="${identities[0]}"
fi
[[ "$identity" == "Developer ID Application:"* ]] || {
  echo "prepare-release: identity must be a Developer ID Application identity" >&2
  exit 1
}

notary_key_id="$(tr -d '[:space:]' < "$notary_key_id_file")"
notary_issuer="$(tr -d '[:space:]' < "$notary_issuer_file")"
[[ "$notary_key_id" =~ ^[A-Za-z0-9]{10,}$ ]] || {
  echo "prepare-release: invalid App Store Connect API key ID" >&2
  exit 1
}
[[ "$notary_issuer" =~ ^[0-9A-Fa-f-]{36}$ ]] || {
  echo "prepare-release: invalid App Store Connect issuer ID" >&2
  exit 1
}

echo "Checking the local App Store Connect notarisation key"
xcrun notarytool history \
  --key "$notary_key" \
  --key-id "$notary_key_id" \
  --issuer "$notary_issuer" >/dev/null

public_key="$(tr -d '[:space:]' < "$public_key_file")"
seed_hex="$(openssl base64 -d -A -in "$sparkle_private_key" | xxd -p -c 256)"
[[ "${#seed_hex}" -eq 64 ]] || {
  echo "prepare-release: Sparkle private key must be base64 for exactly 32 bytes" >&2
  exit 1
}
private_public_key="$({
  printf '302e020100300506032b657004220420%s' "$seed_hex" | xxd -r -p
} | openssl pkey -inform DER -pubout -outform DER 2>/dev/null | tail -c 32 | openssl base64 -A)"
[[ "$private_public_key" == "$public_key" ]] || {
  echo "prepare-release: Sparkle private key does not match app/Release/SparklePublicKey" >&2
  exit 1
}
build="$(( $(git -C "$repo_root" rev-list --count HEAD) * 2 ))"
source_build="$((build - 1))"
work="$(mktemp -d "${TMPDIR:-/tmp}/opentrawl-prepare-release.XXXXXX")"
cleanup() {
  /bin/rm -rf "$work"
}
trap cleanup EXIT
release="$work/release"
source_release="$work/source-release"
assets="$work/assets"

"$script_dir/build-release" \
  --output "$release" \
  --version "$version" \
  --build "$build" \
  --sparkle-public-key "$public_key" \
  --identity "$identity" \
  --notary-key "$notary_key" \
  --notary-key-id "$notary_key_id" \
  --notary-issuer "$notary_issuer" \
  --notarize

"$script_dir/build-release" \
  --output "$source_release" \
  --version 0.0.0 \
  --build "$source_build" \
  --feed-url "http://127.0.0.1:8765/acceptance/appcast.xml" \
  --sparkle-public-key "$public_key" \
  --identity "$identity" \
  --notary-key "$notary_key" \
  --notary-key-id "$notary_key_id" \
  --notary-issuer "$notary_issuer" \
  --notarize

"$script_dir/prepare-update" \
  --release-dir "$release" \
  --notes "$notes" \
  --tag "$tag" \
  --private-key "$sparkle_private_key" \
  --output "$assets"
"$script_dir/prepare-update" \
  --release-dir "$release" \
  --notes "$notes" \
  --tag "$tag" \
  --download-url-prefix "http://127.0.0.1:8765/" \
  --private-key "$sparkle_private_key" \
  --output "$work/acceptance-feed"

mkdir -p "$assets/acceptance"
cp "$source_release/OpenTrawl.dmg" "$assets/acceptance/OpenTrawl-source.dmg"
cp "$work/acceptance-feed/appcast.xml" "$assets/acceptance/appcast.xml"
(
  cd "$assets"
  shasum -a 256 OpenTrawl.dmg appcast.xml > SHA256SUMS
  shasum -a 256 \
    OpenTrawl.dmg \
    appcast.xml \
    acceptance/OpenTrawl-source.dmg \
    acceptance/appcast.xml > CANDIDATE_SHA256SUMS
)

"$script_dir/verify-release" --main-sha "$main" --notarized "$assets"
"$script_dir/verify-release" --main-sha "$main" --notarized --allow-loopback-feed "$source_release"

mkdir -p "$(dirname "$output")"
mv "$assets" "$output"
echo "Prepared unpublished candidate at $output"
echo "Nothing was published or uploaded to GitHub"
echo "The app and disk images were submitted privately to Apple for notarisation"
