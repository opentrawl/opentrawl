#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: app/scripts/prepare-update \
  --release-dir DIR \
  --notes FILE \
  --tag TAG \
  [--download-url-prefix URL] \
  [--private-key FILE] \
  [--sparkle-account ACCOUNT] \
  --output DIR
EOF
  exit 2
}

release_dir=""
notes=""
tag=""
download_url_prefix=""
private_key=""
sparkle_account="ed25519"
output=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --release-dir) release_dir="${2:-}"; shift 2 ;;
    --notes) notes="${2:-}"; shift 2 ;;
    --tag) tag="${2:-}"; shift 2 ;;
    --download-url-prefix) download_url_prefix="${2:-}"; shift 2 ;;
    --private-key) private_key="${2:-}"; shift 2 ;;
    --sparkle-account) sparkle_account="${2:-}"; shift 2 ;;
    --output) output="${2:-}"; shift 2 ;;
    *) usage ;;
  esac
done

[[ -n "$release_dir" && -n "$notes" && -n "$tag" && -n "$sparkle_account" && -n "$output" ]] || usage
if [[ -n "$download_url_prefix" ]]; then
  [[ "$download_url_prefix" == https://* || "$download_url_prefix" == http://127.0.0.1:* ]] || {
    echo "prepare-update: download URL prefix must use https or loopback HTTP" >&2
    exit 1
  }
  [[ "$download_url_prefix" == */ ]] || {
    echo "prepare-update: download URL prefix must end with /" >&2
    exit 1
  }
fi
[[ -f "$release_dir/OpenTrawl.dmg" ]] || {
  echo "prepare-update: missing $release_dir/OpenTrawl.dmg" >&2
  exit 1
}
release_info="$release_dir/OpenTrawl.app/Contents/Info.plist"
[[ -f "$release_info" ]] || {
  echo "prepare-update: missing $release_info" >&2
  exit 1
}
[[ -s "$notes" ]] || {
  echo "prepare-update: release notes must not be empty" >&2
  exit 1
}
if [[ -n "$private_key" && ! -s "$private_key" ]]; then
  echo "prepare-update: Sparkle private key file is missing or empty" >&2
  exit 1
fi
for metadata in VERSION BUILD GIT_COMMIT; do
  [[ -s "$release_dir/$metadata" ]] || {
    echo "prepare-update: missing $release_dir/$metadata" >&2
    exit 1
  }
done
if [[ -e "$output" || -L "$output" ]]; then
  echo "prepare-update: output already exists: $output" >&2
  exit 1
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
app_dir="$(cd "$script_dir/.." && pwd)"
for command in awk openssl plutil xmllint xxd; do
  command -v "$command" >/dev/null || {
    echo "prepare-update: required command is missing: $command" >&2
    exit 1
  }
done
generate_appcast="$release_dir/SparkleTools/generate_appcast"
if [[ ! -x "$generate_appcast" ]]; then
  generate_appcast="$(find "$app_dir/.build/artifacts" -type f -path '*/Sparkle/bin/generate_appcast' -print -quit)"
fi
if [[ -z "$generate_appcast" ]]; then
  echo "prepare-update: build the app package first so Sparkle tools are available" >&2
  exit 1
fi

mkdir -p "$output"
cp "$release_dir/OpenTrawl.dmg" "$output/OpenTrawl.dmg"
awk '
  NR == 1 && $0 == "---" { in_frontmatter = 1; next }
  in_frontmatter && $0 == "---" { in_frontmatter = 0; stripped = 1; next }
  in_frontmatter { next }
  stripped && !started && $0 == "" { next }
  { started = 1; print }
' "$notes" > "$output/OpenTrawl.md"
[[ -s "$output/OpenTrawl.md" ]] || {
  echo "prepare-update: release notes contain no consumer-facing text" >&2
  exit 1
}
cp "$output/OpenTrawl.md" "$output/RELEASE_NOTES.md"
cp "$release_dir/VERSION" "$release_dir/BUILD" "$release_dir/GIT_COMMIT" "$output/"

download_url="${download_url_prefix:-https://github.com/opentrawl/opentrawl/releases/download/$tag/}"
signing_args=(--account "$sparkle_account")
if [[ -n "$private_key" ]]; then
  signing_args=(--ed-key-file "$private_key")
fi
"$generate_appcast" \
  "${signing_args[@]}" \
  --download-url-prefix "$download_url" \
  --embed-release-notes \
  --maximum-versions 1 \
  --maximum-deltas 0 \
  --link "https://github.com/opentrawl/opentrawl" \
  "$output"

[[ -s "$output/appcast.xml" ]] || {
  echo "prepare-update: Sparkle did not produce appcast.xml" >&2
  exit 1
}
grep -q 'sparkle:edSignature=' "$output/appcast.xml" || {
  echo "prepare-update: appcast is unsigned; check that the private key matches the app public key" >&2
  exit 1
}

signature="$(xmllint --xpath 'string(//*[local-name()="enclosure"]/@*[local-name()="edSignature"])' "$output/appcast.xml")"
public_key="$(plutil -extract SUPublicEDKey raw -o - "$release_info")"
if ! openssl pkeyutl \
  -verify \
  -rawin \
  -pubin \
  -keyform DER \
  -inkey <(
    printf '302a300506032b6570032100' | xxd -r -p
    printf '%s' "$public_key" | openssl base64 -d -A
  ) \
  -sigfile <(printf '%s' "$signature" | openssl base64 -d -A) \
  -in "$output/OpenTrawl.dmg" >/dev/null; then
  echo "prepare-update: private update key does not match the public key in OpenTrawl.app" >&2
  exit 1
fi

echo "Prepared update assets in $output"
