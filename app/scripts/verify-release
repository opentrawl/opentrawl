#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: app/scripts/verify-release --main-sha SHA [--notarized] [--allow-loopback-feed] RELEASE_DIR" >&2
  exit 2
}

notarized=0
allow_loopback_feed=0
main_sha=""
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --main-sha)
      main_sha="${2:-}"
      shift
      ;;
    --notarized) notarized=1 ;;
    --allow-loopback-feed) allow_loopback_feed=1 ;;
    *) usage ;;
  esac
  shift
done
[[ $# -eq 1 ]] || usage
[[ "$main_sha" =~ ^[0-9a-f]{40}$ ]] || {
  echo "verify-release: --main-sha must be a full Git commit SHA" >&2
  exit 1
}
release_dir="${1%/}"
dmg="$release_dir/OpenTrawl.dmg"
candidate_commit_file="$release_dir/GIT_COMMIT"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/../.." && pwd)"
expected_background="$repo_root/assets/brand/exports/dmg/background.png"
expected_layout="$repo_root/assets/brand/exports/dmg/layout.dsstore"
[[ -f "$dmg" ]] || {
  echo "verify-release: missing $dmg" >&2
  exit 1
}
[[ -s "$candidate_commit_file" ]] || {
  echo "verify-release: missing $candidate_commit_file" >&2
  exit 1
}

mount="$(mktemp -d "${TMPDIR:-/tmp}/opentrawl-dmg.XXXXXX")"
device=""
detach() {
  if [[ -n "$device" ]]; then
    diskutil eject "$device" >/dev/null 2>&1 || true
  fi
}
trap detach EXIT

attach_output="$(diskutil image attach --readOnly --nobrowse --mountPoint "$mount" "$dmg")"
device="$(printf '%s\n' "$attach_output" | awk 'NR == 1 { print $1 }')"
app="$mount/OpenTrawl.app"
info="$app/Contents/Info.plist"
cli="$app/Contents/Helpers/trawl"
photos="$app/Contents/Helpers/Photoscrawl Fetch.app/Contents/MacOS/photoscrawl-fetch"

[[ -d "$app" && -L "$mount/Applications" && "$(readlink "$mount/Applications")" == "/Applications" ]]
[[ -f "$mount/.DS_Store" && -f "$mount/.background/background.png" ]]
cmp "$expected_layout" "$mount/.DS_Store"
cmp "$expected_background" "$mount/.background/background.png"
[[ -x "$app/Contents/MacOS/Trawl" && -x "$cli" ]]
[[ -d "$app/Contents/Frameworks/Sparkle.framework" ]]
[[ -d "$app/Contents/Helpers/Photoscrawl Fetch.app" ]]

[[ "$(plutil -extract CFBundleIdentifier raw -o - "$info")" == "org.opentrawl.trawl" ]]
feed_url="$(plutil -extract SUFeedURL raw -o - "$info")"
if [[ "$allow_loopback_feed" -eq 1 ]]; then
  [[ "$feed_url" == https://* || "$feed_url" == http://127.0.0.1:* ]]
elif [[ "$notarized" -eq 1 ]]; then
  [[ "$feed_url" == https://* ]]
else
  [[ "$feed_url" == https://* || "$feed_url" == http://127.0.0.1:* ]]
fi
[[ "$(plutil -extract SUEnableAutomaticChecks raw -o - "$info")" == "true" ]]
[[ "$(plutil -extract SUAutomaticallyUpdate raw -o - "$info")" == "false" ]]
[[ "$(plutil -extract SUAllowsAutomaticUpdates raw -o - "$info")" == "false" ]]
[[ "$(plutil -extract SUEnableSystemProfiling raw -o - "$info")" == "false" ]]

codesign --verify --deep --strict --verbose=2 "$app"
codesign --verify --strict --verbose=2 "$dmg"

candidate_commit="$(<"$candidate_commit_file")"
embedded_commit="$(plutil -extract GitCommit raw -o - "$info")"
[[ "$candidate_commit" =~ ^[0-9a-f]{40}$ ]] || {
  echo "verify-release: candidate GIT_COMMIT is not a full Git commit SHA" >&2
  exit 1
}
[[ "$embedded_commit" == "$candidate_commit" ]] || {
  echo "verify-release: signed app GitCommit does not match candidate GIT_COMMIT" >&2
  exit 1
}
[[ "$candidate_commit" == "$main_sha" ]] || {
  echo "verify-release: candidate GIT_COMMIT does not match nominated main SHA" >&2
  exit 1
}

while IFS= read -r library; do
  case "$library" in
    /usr/lib/*|/System/Library/*|@rpath/*|@loader_path/*|@executable_path/*) ;;
    *)
      echo "verify-release: bundled CLI has an external dynamic library: $library" >&2
      exit 1
      ;;
  esac
done < <(otool -L "$cli" | awk 'NR > 1 { print $1 }')

version="$(plutil -extract CFBundleShortVersionString raw -o - "$info")"
[[ "$($cli --version)" == "$version" ]]
"$cli" --help >/dev/null

minimum="$(plutil -extract LSMinimumSystemVersion raw -o - "$info")"
for binary in "$app/Contents/MacOS/Trawl" "$cli" "$photos"; do
  minos="$(xcrun vtool -show-build "$binary" | awk '$1 == "minos" { print $2 }')"
  [[ -n "$minos" && "$minos" == "$minimum" ]] || {
    echo "verify-release: $binary requires macOS ${minos:-unknown}, expected $minimum" >&2
    exit 1
  }
done

if [[ "$notarized" -eq 1 ]]; then
  spctl --assess --type execute --verbose=2 "$app"
  spctl --assess --type open --context context:primary-signature --verbose=2 "$dmg"
  xcrun stapler validate "$app"
  xcrun stapler validate "$dmg"
fi

echo "verify-release: OpenTrawl $version is structurally valid"
