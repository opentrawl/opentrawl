#!/usr/bin/python3

import os
import sys
import time


def varint(value):
    encoded = bytearray()
    while True:
        byte = value & 0x7F
        value >>= 7
        if value:
            encoded.append(byte | 0x80)
        else:
            encoded.append(byte)
            return bytes(encoded)


def string_field(number, value):
    data = value.encode("utf-8")
    return varint(number << 3 | 2) + varint(len(data)) + data


def integer_field(number, value):
    return varint(number << 3) + varint(value)


def message_field(number, value):
    return varint(number << 3 | 2) + varint(len(value)) + value


def count(identifier, display):
    return string_field(1, identifier) + string_field(2, display)


def source(identifier, name, state, summary, display, synced, archive_bytes):
    payload = b"".join(
        [
            string_field(1, identifier),
            string_field(2, name),
            string_field(3, state),
            string_field(4, summary),
            message_field(5, count("items", display)),
            string_field(6, synced),
            integer_field(7, archive_bytes),
        ]
    )
    return varint(len(payload)) + payload


def hit(reference, source_id, title, snippet, when):
    payload = b"".join(
        [
            string_field(1, reference),
            string_field(2, source_id),
            string_field(3, title),
            string_field(4, snippet),
            string_field(5, when),
        ]
    )
    return varint(len(payload)) + payload


def write(data):
    os.write(sys.stdout.fileno(), data)


def status():
    write(source("imessage", "Messages", "ok", "Recently synced.", "27 messages", "1h ago", 620_000))
    write(source("whatsapp", "WhatsApp", "ok", "Recently synced.", "31 messages", "45m ago", 710_000))
    write(source("telegram", "Telegram", "ok", "Recently synced.", "24 messages", "2h ago", 520_000))
    write(source("gmail", "Gmail", "ok", "Recently synced.", "42 messages", "just now", 840_000))
    write(source("calendar", "Calendar", "ok", "Recently synced.", "12 events", "30m ago", 180_000))
    write(source("contacts", "Contacts", "ok", "Recently synced.", "8 people", "1d ago", 140_000))
    write(source("photos", "Photos", "stale", "Sync recommended.", "16 photos", "2d ago", 1_900_000))
    write(source("twitter", "X", "ok", "Recently synced.", "18 posts", "12m ago", 360_000))
    write(source("notes", "Notes", "ok", "Recently synced.", "9 notes", "3h ago", 210_000))
    return 0


def search(arguments):
    query = arguments[-1].strip().lower() if arguments else ""
    scoped = None
    if "--source" in arguments:
        position = arguments.index("--source")
        if position + 1 < len(arguments):
            scoped = arguments[position + 1]

    if query == "timeout":
        time.sleep(30)
        return 0
    if query == "failed":
        print("synthetic total failure", file=sys.stderr)
        return 1
    if query == "none":
        return 0

    rows = [
        (
            "gmail:message:example-1",
            "gmail",
            "Avery Example",
            "Project Lantern is ready for a final review.",
            "10 Jul",
        ),
        (
            "imessage:message:example-2",
            "imessage",
            "+15550001111",
            "The synthetic pickup moved to Friday at 14:00.",
            "9 Jul",
        ),
        (
            "notes:note:example-3",
            "notes",
            "Packing list",
            "Passport, charger and the example train ticket.",
            "8 Jul",
        ),
    ]
    for row in rows:
        if scoped is None or row[1] == scoped:
            write(hit(*row))
    if query == "partial":
        print("one synthetic source failed", file=sys.stderr)
        return 3
    return 0


def open_result(reference):
    output = """Source: Gmail
From: Avery Example <avery@example.com>
Subject: Project Lantern
Date: 10 July 2026

Project Lantern is ready for a final review.
"""
    if reference.startswith("imessage:"):
        output = """Source: Messages
From: +15550001111
Date: 9 July 2026

The synthetic pickup moved to Friday at 14:00.
"""
    elif reference.startswith("notes:"):
        output = """Source: Notes
Title: Packing list

Passport, charger and the example train ticket.
"""
    sys.stdout.write(output)
    return 0


def main():
    arguments = sys.argv[1:]
    if arguments[:2] == ["__app", "status"]:
        return status()
    if arguments[:2] == ["__app", "sync"]:
        return 0
    if arguments[:2] == ["__app", "search"]:
        return search(arguments[2:])
    if arguments[:1] == ["open"] and len(arguments) == 2:
        return open_result(arguments[1])
    print("unsupported synthetic command", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
